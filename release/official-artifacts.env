# Official publication targets for OurBox Matchbox.
# These values are repo-defined and must never be accepted from workflow inputs
# in the official publication lane.

OURBOX_TARGET=rpi
OURBOX_MODEL_ID=TOO-OBX-MBX-01
OURBOX_SKU=TOO-OBX-MBX-BASE-001
OURBOX_VARIANT=prod

OFFICIAL_OS_REPO=ghcr.io/techofourown/ourbox-matchbox-os
OFFICIAL_OS_ARTIFACT_KIND=os-image
OFFICIAL_OS_ARTIFACT_TYPE=application/vnd.techofourown.ourbox.matchbox.os-image.v1
OFFICIAL_OS_CATALOG_TAG=rpi-catalog
OFFICIAL_OS_CATALOG_ARTIFACT_TYPE=application/vnd.techofourown.ourbox.matchbox.os-catalog.v1
OFFICIAL_OS_CATALOG_CHANNEL_MODE=target-qualified
OFFICIAL_OS_CATALOG_SHA_COLUMN=img_sha256
OFFICIAL_OS_BETA_CHANNELS="rpi-beta"
OFFICIAL_OS_STABLE_CHANNELS="rpi-stable"
OFFICIAL_OS_NIGHTLY_CHANNELS="rpi-nightly"
OFFICIAL_OS_EXP_LABS_CHANNELS="rpi-exp-labs"

OFFICIAL_INSTALLER_REPO=ghcr.io/techofourown/ourbox-matchbox-installer
OFFICIAL_INSTALLER_ARTIFACT_KIND=installer-image
OFFICIAL_INSTALLER_ARTIFACT_TYPE=application/vnd.techofourown.ourbox.matchbox.installer-image.v1
OFFICIAL_INSTALLER_BETA_CHANNELS="rpi-installer-beta"
OFFICIAL_INSTALLER_STABLE_CHANNELS="rpi-installer-stable"
OFFICIAL_INSTALLER_NIGHTLY_CHANNELS="rpi-installer-nightly"
OFFICIAL_INSTALLER_EXP_LABS_CHANNELS="rpi-installer-exp-labs"
