# Official publication targets for OurBox Matchbox.
# These values are repo-defined and must never be accepted from workflow inputs
# in the official publication lane.

OURBOX_TARGET=rpi
OURBOX_MODEL_ID=TOO-OBX-MBX-01
OURBOX_SKU=TOO-OBX-MBX-BASE-001
OURBOX_VARIANT=prod

OFFICIAL_OS_REPO=ghcr.io/techofourown/ourbox-matchbox-os
OFFICIAL_OS_CATALOG_TAG=rpi-catalog
OFFICIAL_OS_NIGHTLY_CHANNELS="rpi-nightly"
OFFICIAL_OS_RELEASE_CHANNELS="rpi-stable"

OFFICIAL_INSTALLER_REPO=ghcr.io/techofourown/ourbox-matchbox-installer
OFFICIAL_INSTALLER_NIGHTLY_CHANNELS="rpi-installer-nightly"
OFFICIAL_INSTALLER_RELEASE_CHANNELS="rpi-installer-stable"
