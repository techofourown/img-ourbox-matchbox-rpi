matchbox_partition_path() {
  local disk="$1"
  local part_num="$2"

  if [[ "${disk}" =~ [0-9]$ ]]; then
    printf '%s\n' "${disk}p${part_num}"
  else
    printf '%s\n' "${disk}${part_num}"
