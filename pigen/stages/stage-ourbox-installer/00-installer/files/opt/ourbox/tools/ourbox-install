#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC1091
source /opt/ourbox/tools/lib.sh

need_cmd xz
need_cmd xzcat
need_cmd sha256sum
need_cmd dd
need_cmd lsblk
need_cmd readlink
need_cmd findmnt
need_cmd blkid
need_cmd partprobe
need_cmd wipefs
need_cmd blockdev
need_cmd parted
need_cmd mkfs.ext4
need_cmd mount
need_cmd umount
need_cmd mountpoint
need_cmd find
need_cmd openssl
need_cmd sync
need_cmd curl
need_cmd tar

DATA_CHECK_MP="/run/ourbox-installer/data-check"
SYS_BOOT_MP="/run/ourbox-installer/sys-boot"
PAYLOAD_DIR="/opt/ourbox/installer/cache/payload"
CATALOG_DIR="/opt/ourbox/installer/cache/catalog"
DEFAULTS_ENV="/opt/ourbox/installer/defaults.env"
OVERRIDE_ENV="/boot/firmware/ourbox-installer.env"

OS_REPO=""
OS_TARGET=""
OS_CHANNEL=""
OS_CATALOG_ENABLED=1
OS_CATALOG_TAG=""
OS_ARTIFACT_TYPE=""
OS_ORAS_VERSION=""
OS_REF=""
OS_REGISTRY_USERNAME=""
OS_REGISTRY_PASSWORD=""
SELECTED_REF=""
SELECTED_TAG=""
PAYLOAD_PATH=""
PAYLOAD_SHA256=""
PAYLOAD_META=""

cleanup_mounts() {
  if mountpoint -q "${DATA_CHECK_MP}"; then
    umount "${DATA_CHECK_MP}" >/dev/null 2>&1 || true
  fi
  if mountpoint -q "${SYS_BOOT_MP}"; then
    umount "${SYS_BOOT_MP}" >/dev/null 2>&1 || true
  fi
}

cleanup_temp() {
  rm -rf "${PAYLOAD_DIR}" "${CATALOG_DIR}"
}

finalize() {
  local rc=$?
  trap - EXIT
  cleanup_mounts

  echo
  if [[ "${rc}" -eq 0 ]]; then
    log "Installer finished (success). Powering off now."
    sync || true
    systemctl poweroff || /sbin/poweroff || true
    exit 0
  fi

  log "ERROR: Installer failed (rc=${rc})."
  log "Dropping to an interactive shell for debugging."
  log "When you're done, type: poweroff"

  exec /bin/bash -l
}
trap finalize EXIT

prompt_confirm_exact() {
  local expected="$1"
  local prompt="$2"
  local ans=""
  read -r -p "${prompt} " ans
  [[ "${ans}" == "${expected}" ]] || die "confirmation did not match (expected: ${expected})"
}

nvme_disks() {
  lsblk -dn -o NAME,TYPE | awk '$2=="disk" && $1 ~ /^nvme[0-9]+n[0-9]+$/ {print "/dev/"$1}'
}

parent_disk_of_part() {
  local part="$1"
  echo "/dev/$(lsblk -no PKNAME "${part}")"
}

show_nvme_summary() {
  local disks=("$@")
  lsblk -o NAME,SIZE,MODEL,SERIAL,TYPE,FSTYPE,LABEL,MOUNTPOINTS "${disks[@]}" || true
}

unmount_anything_on_disk() {
  local disk="$1"
  while read -r name mp; do
    [[ -n "${mp}" ]] || continue
    umount "/dev/${name}" >/dev/null 2>&1 || umount "${mp}" >/dev/null 2>&1 || true
  done < <(lsblk -nr -o NAME,MOUNTPOINT "${disk}" | awk 'NF==2 && $2!="" {print $1, $2}')
}

require_unmounted_disk() {
  local disk="$1"
  unmount_anything_on_disk "${disk}"
  if lsblk -nr -o MOUNTPOINT "${disk}" | awk 'NF && $0 != "" {found=1} END{exit !found}'; then
    lsblk -o NAME,SIZE,FSTYPE,LABEL,MOUNTPOINTS "${disk}" || true
    die "could not unmount all partitions on ${disk}"
  fi
}

zero_head_tail() {
  local disk="$1"
  local zero_mib="${ZERO_MIB:-32}"

  dd if=/dev/zero of="${disk}" bs=1M count="${zero_mib}" conv=fsync status=progress

  local size_bytes total_mib seek_mib
  size_bytes="$(blockdev --getsize64 "${disk}")"
  total_mib="$((size_bytes / 1024 / 1024))"
  if (( total_mib > zero_mib )); then
    seek_mib="$((total_mib - zero_mib))"
    dd if=/dev/zero of="${disk}" bs=1M count="${zero_mib}" seek="${seek_mib}" conv=fsync status=progress
  fi
}

init_data_disk_ext4_labeled() {
  local disk="$1"
  local ask_confirm="${2:-1}"

  require_unmounted_disk "${disk}"
  if [[ "${ask_confirm}" == "1" ]]; then
    prompt_confirm_exact "ERASE-DATA" "Type ERASE-DATA to confirm DATA disk erase:"
  fi

  if command -v blkdiscard >/dev/null 2>&1; then
    blkdiscard -f "${disk}" >/dev/null 2>&1 || true
  fi
  wipefs -a "${disk}" >/dev/null 2>&1 || true
  zero_head_tail "${disk}"
  sync

  parted -s "${disk}" mklabel gpt
  parted -s "${disk}" mkpart primary ext4 1MiB 100%
  partprobe "${disk}" || true

  local part="${disk}p1"
  mkfs.ext4 -F -L OURBOX_DATA "${part}"
  sync

  local resolved
  resolved="$(resolve_label OURBOX_DATA)"
  [[ -n "${resolved}" ]] || die "OURBOX_DATA label not resolvable after format"
  [[ "$(readlink -f "${resolved}")" == "$(readlink -f "${part}")" ]] || {
    die "OURBOX_DATA resolves to ${resolved}, expected ${part}"
  }
}

inspect_data_partition() {
  local dpart="$1"

  DATA_HAS_CONTENT=0
  DATA_BOOTSTRAP_DONE=0

  mkdir -p "${DATA_CHECK_MP}"
  if mountpoint -q "${DATA_CHECK_MP}"; then
    umount "${DATA_CHECK_MP}" >/dev/null 2>&1 || true
  fi

  if ! mount -t ext4 -o ro,noload "${dpart}" "${DATA_CHECK_MP}" >/dev/null 2>&1; then
    mount -t ext4 -o ro "${dpart}" "${DATA_CHECK_MP}" >/dev/null 2>&1 || return 1
  fi

  if [[ -f "${DATA_CHECK_MP}/state/bootstrap.done" ]]; then
    DATA_BOOTSTRAP_DONE=1
  fi

  local found
  found="$(find "${DATA_CHECK_MP}" -mindepth 1 -maxdepth 1 ! -name lost+found -print -quit 2>/dev/null || true)"
  if [[ -n "${found}" ]]; then
    DATA_HAS_CONTENT=1
  fi

  umount "${DATA_CHECK_MP}" >/dev/null 2>&1 || true
  return 0
}

reset_data_bootstrap_marker() {
  local dpart="$1"

  mkdir -p "${DATA_CHECK_MP}"
  if mountpoint -q "${DATA_CHECK_MP}"; then
    umount "${DATA_CHECK_MP}" >/dev/null 2>&1 || true
  fi

  mount -t ext4 -o rw "${dpart}" "${DATA_CHECK_MP}"
  rm -f "${DATA_CHECK_MP}/state/bootstrap.done"
  sync
  umount "${DATA_CHECK_MP}" >/dev/null 2>&1 || true
}

load_payload_config() {
  # shellcheck disable=SC1090
  [[ -f "${DEFAULTS_ENV}" ]] && source "${DEFAULTS_ENV}"
  # shellcheck disable=SC1090
  [[ -f "${OVERRIDE_ENV}" ]] && source "${OVERRIDE_ENV}"

  OS_REPO="${OS_REPO:-ghcr.io/techofourown/ourbox-matchbox-os}"
  OS_TARGET="${OS_TARGET:-rpi}"
  OS_CHANNEL="${OS_CHANNEL:-stable}"
  OS_CATALOG_ENABLED="${OS_CATALOG_ENABLED:-1}"
  OS_CATALOG_TAG="${OS_CATALOG_TAG:-${OS_TARGET}-catalog}"
  OS_ARTIFACT_TYPE="${OS_ARTIFACT_TYPE:-application/vnd.ourbox.matchbox.os-image.v1}"
  OS_ORAS_VERSION="${OS_ORAS_VERSION:-1.3.0}"
  OS_REF="${OS_REF:-}"
  OS_REGISTRY_USERNAME="${OS_REGISTRY_USERNAME:-}"
  OS_REGISTRY_PASSWORD="${OS_REGISTRY_PASSWORD:-}"
}

map_arch() {
  case "$(uname -m)" in
    x86_64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) die "unsupported architecture: $(uname -m)" ;;
  esac
}

ensure_oras() {
  local desired="v${OS_ORAS_VERSION}"
  if command -v oras >/dev/null 2>&1; then
    local current
    current="$(oras version 2>/dev/null | awk '/Version:/ {print $2}' || true)"
    if [[ "${current}" == "${OS_ORAS_VERSION}" || "${current}" == "${desired#v}" ]]; then
      log "ORAS already present (${current})"
      return 0
    fi
    log "ORAS present but not ${OS_ORAS_VERSION}; upgrading"
  else
    log "Installing ORAS ${OS_ORAS_VERSION}"
  fi

  local arch url tmpdir
  arch="$(map_arch)"
  url="https://github.com/oras-project/oras/releases/download/v${OS_ORAS_VERSION}/oras_${OS_ORAS_VERSION}_linux_${arch}.tar.gz"
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "${tmpdir}"' RETURN
  curl -fsSL -o "${tmpdir}/oras.tgz" "${url}"
  tar -C "${tmpdir}" -xzf "${tmpdir}/oras.tgz" oras
  install -m 0755 "${tmpdir}/oras" /usr/local/bin/oras
  trap - RETURN
  rm -rf "${tmpdir}"
  log "ORAS installed: $(oras version 2>/dev/null | tr -d \"\r\")"
}

maybe_oras_login() {
  if [[ -n "${OS_REGISTRY_USERNAME}" ]]; then
    log "Logging into registry for ${OS_REPO}"
    oras login "$(echo "${OS_REPO}" | cut -d/ -f1)" -u "${OS_REGISTRY_USERNAME}" --password "${OS_REGISTRY_PASSWORD:-}" >/dev/null
  fi
}

ensure_dirs() {
  cleanup_temp
  mkdir -p "${PAYLOAD_DIR}" "${CATALOG_DIR}"
}

wait_for_network() {
  local retries=40
  local ok=0
  for _i in $(seq 1 "${retries}"); do
    if ip -o -4 addr show up scope global | grep -q .; then
      ok=1
      break
    fi
    sleep 0.5
  done
  [[ "${ok}" -eq 1 ]] || die "network not ready (no global IPv4 after ${retries} attempts)"
}

banner() {
  echo "=================================================================="
  echo "OurBox Matchbox Installer"
  echo "=================================================================="
}

show_default_choice() {
  local ref="$1"
  echo
  echo "Default: install '${ref}'"
  echo "Options:"
  echo "  [ENTER] Use default"
  echo "  c       Choose channel (stable/beta/nightly/exp-labs/custom)"
  echo "  l       List from catalog (if available)"
  echo "  r       Enter custom OCI ref (tag or digest)"
  echo "  q       Quit"
  echo
}

choose_channel() {
  local base="${OS_REPO}:${OS_TARGET}-"
  echo "Channels:"
  echo "  1) ${base}stable (recommended)"
  echo "  2) ${base}beta"
  echo "  3) ${base}nightly"
  echo "  4) ${base}exp-labs"
  echo "  5) custom channel name"
  local pick=""
  read -r -p "Select channel [1-5]: " pick
  case "${pick}" in
    1|"") SELECTED_REF="${base}stable" ;;
    2) SELECTED_REF="${base}beta" ;;
    3) SELECTED_REF="${base}nightly" ;;
    4) SELECTED_REF="${base}exp-labs" ;;
    5)
      local ch=""
      read -r -p "Enter channel suffix: " ch
      [[ -n "${ch}" ]] || die "channel cannot be empty"
      SELECTED_REF="${base}${ch}"
      ;;
    *) log "Invalid choice, using default";;
  esac
}

pull_catalog() {
  [[ "${OS_CATALOG_ENABLED}" == "1" ]] || return 1
  local dst="$1"
  local ref="${OS_REPO}:${OS_CATALOG_TAG}"
  rm -rf "${dst}"
  mkdir -p "${dst}"
  log "Pulling catalog: ${ref}"
  if oras pull "${ref}" -o "${dst}" >/dev/null 2>&1; then
    [[ -f "${dst}/catalog.tsv" ]] || return 1
    CATALOG_REF="${ref}"
    return 0
  fi
  return 1
}

select_from_catalog() {
  CATALOG_REF=""
  pull_catalog "${CATALOG_DIR}" || { log "Catalog unavailable; skipping list."; return 1; }
  local catalog="${CATALOG_DIR}/catalog.tsv"

  mapfile -t entries < <(awk -F'\t' 'NR==1 && $1 ~ /channel/ {next} NF>=2 {print NR ":" $0}' "${catalog}")
  if [[ "${#entries[@]}" -eq 0 ]]; then
    log "Catalog pulled (${catalog_ref}) but contained no entries."
    return 1
  fi

  echo
  echo "Catalog entries (${CATALOG_REF}):"
  local i=1
  for line in "${entries[@]}"; do
    IFS=$'\t' read -r channel tag created version variant target sku gitsha contract k3s imgsha <<<"${line#*:}"
    printf "  %d) %-12s %-30s %s %s %s\n" "${i}" "${channel}" "${tag}" "${version}" "${created}" "${contract}"
    i=$((i+1))
  done

  local pick=""
  read -r -p "Choose entry [1-${#entries[@]}] (or ENTER to cancel): " pick
  [[ -z "${pick}" ]] && return 1
  [[ "${pick}" =~ ^[0-9]+$ ]] || { log "Invalid selection"; return 1; }
  if (( pick < 1 || pick > ${#entries[@]} )); then
    log "Selection out of range"
    return 1
  fi
  local chosen="${entries[$((pick-1))]}"
  IFS=$'\t' read -r channel tag created version variant target sku gitsha contract k3s imgsha <<<"${chosen#*:}"
  SELECTED_TAG="${tag}"
  SELECTED_REF="${OS_REPO}:${tag}"
  log "Selected ${SELECTED_REF} (channel=${channel}, version=${version}, contract=${contract})"
  return 0
}

select_payload_ref() {
  SELECTED_REF=""
  local default_ref
  if [[ -n "${OS_REF}" ]]; then
    default_ref="${OS_REF}"
  else
    default_ref="${OS_REPO}:${OS_TARGET}-${OS_CHANNEL}"
  fi

  while [[ -z "${SELECTED_REF}" ]]; do
    show_default_choice "${default_ref}"
    local choice=""
    read -r -p "Choice: " choice
    case "${choice}" in
      "" ) SELECTED_REF="${default_ref}" ;;
      c ) choose_channel ;;
      l ) select_from_catalog || true ;;
      r )
        read -r -p "Enter full OCI ref (e.g., repo:tag or repo@sha256:...): " ref
        [[ -n "${ref}" ]] || { log "Ref cannot be empty"; continue; }
        SELECTED_REF="${ref}"
        ;;
      q|Q ) die "Install aborted by user" ;;
      * ) log "Unknown option" ;;
    esac
  done
}

parse_sha256_file() {
  local file="$1"
  awk 'NF>=1 {print $1; exit}' "${file}"
}

pull_payload() {
  local ref="$1"
  rm -rf "${PAYLOAD_DIR}"
  mkdir -p "${PAYLOAD_DIR}"
  log "Pulling OS payload: ${ref}"
  oras pull "${ref}" -o "${PAYLOAD_DIR}"

  PAYLOAD_PATH="${PAYLOAD_DIR}/os.img.xz"
  [[ -f "${PAYLOAD_PATH}" ]] || die "oras pull succeeded but os.img.xz missing from payload"

  PAYLOAD_META="${PAYLOAD_DIR}/os.meta.env"

  local sha_file="${PAYLOAD_DIR}/os.img.xz.sha256"
  if [[ -f "${sha_file}" ]]; then
    PAYLOAD_SHA256="$(parse_sha256_file "${sha_file}")"
  else
    PAYLOAD_SHA256=""
  fi

  local actual_sha
  actual_sha="$(sha256sum "${PAYLOAD_PATH}" | awk '{print $1}')"
  if [[ -n "${PAYLOAD_SHA256}" && "${PAYLOAD_SHA256}" != "${actual_sha}" ]]; then
    die "payload SHA mismatch (expected ${PAYLOAD_SHA256}, got ${actual_sha})"
  fi
  PAYLOAD_SHA256="${actual_sha}"
}

show_payload_metadata() {
  echo
  echo "Payload source : ${SELECTED_REF}"
  echo "Payload sha256 : ${PAYLOAD_SHA256}"
  if [[ -f "${PAYLOAD_META}" ]]; then
    echo "Payload metadata:"
    while IFS='=' read -r k v; do
      [[ -z "${k}" ]] && continue
      printf "  %s=%s\n" "${k}" "${v}"
    done < "${PAYLOAD_META}"
  else
    echo "Payload metadata: (os.meta.env not present)"
  fi
  echo
}

main() {
  banner

  load_payload_config
  ensure_dirs
  ensure_oras
  wait_for_network
  maybe_oras_login
  select_payload_ref
  pull_payload "${SELECTED_REF}"

  log "Verifying compressed payload integrity"
  xz -t "${PAYLOAD_PATH}"

  show_payload_metadata

  log "Running hard safety preflight"
  local root_src root_real root_parent
  root_src="$(findmnt -nr -o SOURCE / 2>/dev/null || true)"
  root_real="$(readlink -f "${root_src}" 2>/dev/null || echo "${root_src}")"
  root_parent="$(lsblk -no PKNAME "${root_real}" 2>/dev/null || true)"
  if [[ -n "${root_parent}" ]]; then
    root_real="/dev/${root_parent}"
  fi
  [[ "${root_real}" != /dev/nvme* ]] || die "root filesystem is on NVMe (${root_real}); boot installer from SD/USB"

  log "Waiting for exactly 2 NVMe disks to enumerate"
  local disks=()
  for _i in $(seq 1 40); do
    mapfile -t disks < <(nvme_disks)
    [[ "${#disks[@]}" -eq 2 ]] && break
    sleep 0.5
  done

  if [[ "${#disks[@]}" -ne 2 ]]; then
    lsblk -o NAME,SIZE,MODEL,SERIAL,TYPE,FSTYPE,LABEL,MOUNTPOINTS || true
    die "expected exactly 2 NVMe disks, found ${#disks[@]}"
  fi

  if lsblk -nr -o MOUNTPOINT "${disks[@]}" | awk 'NF && $0 != "" {found=1} END{exit !found}'; then
    lsblk -o NAME,FSTYPE,LABEL,MOUNTPOINTS "${disks[@]}" || true
    die "NVMe partitions are mounted; unmount and retry"
  fi

  log "Enforcing DATA contract"
  local dpart ddisk fstype
  dpart="$(resolve_label OURBOX_DATA)"

  if [[ -n "${dpart}" ]]; then
    dpart="$(readlink -f "${dpart}")"
    fstype="$(lsblk -no FSTYPE "${dpart}" 2>/dev/null || true)"
    [[ "${fstype}" == "ext4" ]] || die "OURBOX_DATA exists but is not ext4 (${fstype:-unknown})"
    ddisk="$(parent_disk_of_part "${dpart}")"
    [[ "${ddisk}" == "${disks[0]}" || "${ddisk}" == "${disks[1]}" ]] || die "OURBOX_DATA is not on detected NVMe disks"
  else
    show_nvme_summary "${disks[@]}"
    echo "Choose DATA disk:"
    echo "  1) ${disks[0]}"
    echo "  2) ${disks[1]}"
    local pick=""
    read -r -p "Enter 1 or 2: " pick
    case "${pick}" in
      1) ddisk="${disks[0]}" ;;
      2) ddisk="${disks[1]}" ;;
      *) die "invalid choice" ;;
    esac

    init_data_disk_ext4_labeled "${ddisk}" 1
    dpart="$(resolve_label OURBOX_DATA)"
    [[ -n "${dpart}" ]] || die "failed to resolve OURBOX_DATA after creation"
    dpart="$(readlink -f "${dpart}")"
    [[ "${dpart}" == "$(readlink -f "${ddisk}p1")" ]] || die "OURBOX_DATA resolves to ${dpart}, expected ${ddisk}p1"
  fi

  require_unmounted_disk "${ddisk}"

  if ! inspect_data_partition "${dpart}"; then
    die "could not inspect DATA partition; refusing to proceed"
  fi

  if [[ "${DATA_HAS_CONTENT}" -eq 1 ]]; then
    echo "DATA partition has existing content: ${dpart}"
    if [[ "${DATA_BOOTSTRAP_DONE}" -eq 1 ]]; then
      echo "Detected /state/bootstrap.done. KEEP-DATA will skip bootstrap and k3s will not auto-start."
      echo "Recommended: RESET-BOOTSTRAP"
    else
      echo "No /state/bootstrap.done detected. Recommended: ERASE-DATA"
    fi

    local data_choice=""
    read -r -p "Type RESET-BOOTSTRAP, ERASE-DATA, or KEEP-DATA: " data_choice
    case "${data_choice}" in
      RESET-BOOTSTRAP)
        reset_data_bootstrap_marker "${dpart}"
        ;;
      ERASE-DATA)
        init_data_disk_ext4_labeled "${ddisk}" 0
        dpart="$(resolve_label OURBOX_DATA)"
        [[ -n "${dpart}" ]] || die "failed to resolve OURBOX_DATA after ERASE-DATA"
        dpart="$(readlink -f "${dpart}")"
        ;;
      KEEP-DATA)
        echo "KEEP-DATA selected. Warning: bootstrap behavior may remain suppressed."
        ;;
      *)
        die "invalid DATA action"
        ;;
    esac
  fi

  local sys_disk
  if [[ "${ddisk}" == "${disks[0]}" ]]; then
    sys_disk="${disks[1]}"
  else
    sys_disk="${disks[0]}"
  fi

  echo
  echo "Disk selection summary:"
  echo "  DATA   : ${ddisk} (partition ${dpart}, LABEL=OURBOX_DATA)"
  echo "  SYSTEM : ${sys_disk} (will be wiped)"
  echo

  prompt_confirm_exact "${sys_disk}" "Type the SYSTEM disk path exactly to continue:"
  prompt_confirm_exact "FLASH" "Type FLASH to wipe and flash SYSTEM:"

  log "Preparing SYSTEM disk"
  require_unmounted_disk "${sys_disk}"
  if command -v blkdiscard >/dev/null 2>&1; then
    blkdiscard -f "${sys_disk}" >/dev/null 2>&1 || true
  fi
  wipefs -a "${sys_disk}" >/dev/null 2>&1 || true
  zero_head_tail "${sys_disk}"
  sync

  log "Flashing payload to SYSTEM"
  xzcat "${PAYLOAD_PATH}" | dd of="${sys_disk}" bs=4M conv=fsync status=progress
  sync

  partprobe "${sys_disk}" || true
  lsblk -f "${sys_disk}"

  local username passhash
  read -r -p "Username for first boot [ourbox]: " username
  username="${username:-ourbox}"
  passhash="$(openssl passwd -6)"

  mkdir -p "${SYS_BOOT_MP}"
  if mountpoint -q "${SYS_BOOT_MP}"; then
    umount "${SYS_BOOT_MP}" >/dev/null 2>&1 || true
  fi

  mount "${sys_disk}p1" "${SYS_BOOT_MP}"
  printf '%s:%s\n' "${username}" "${passhash}" > "${SYS_BOOT_MP}/userconf.txt"
  sync
  umount "${SYS_BOOT_MP}"
  log "userconf written"

  echo
  echo "Remove installer media"
  echo "Boot from NVMe"
}

main "$@"
