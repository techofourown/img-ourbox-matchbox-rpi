parse_sha256_file() {
  local file="$1"
  awk 'NF>=1 {print $1; exit}' "${file}"
}

finalize_selected_payload_ref() {
  ourbox_selection_finalize_registry_ref "${SELECTED_REF}"
  PULL_REF="${OURBOX_PULL_REF}"
  OS_ARTIFACT_SOURCE="${OURBOX_OS_ARTIFACT_SOURCE}"
  OS_ARTIFACT_REF="${OURBOX_OS_ARTIFACT_REF}"
  OS_ARTIFACT_DIGEST="${OURBOX_OS_ARTIFACT_DIGEST}"
}

pull_payload() {
  rm -rf "${PAYLOAD_DIR}"
  mkdir -p "${PAYLOAD_DIR}"
  log "Pulling OS payload: ${PULL_REF}"
  oras pull "${PULL_REF}" -o "${PAYLOAD_DIR}"

  PAYLOAD_PATH="${PAYLOAD_DIR}/os.img.xz"
  [[ -f "${PAYLOAD_PATH}" ]] || die "oras pull succeeded but os.img.xz missing from payload"

  PAYLOAD_META="${PAYLOAD_DIR}/os.meta.env"

  local sha_file="${PAYLOAD_DIR}/os.img.xz.sha256"
  [[ -f "${sha_file}" ]] || die "payload missing os.img.xz.sha256"
  PAYLOAD_SHA256="$(parse_sha256_file "${sha_file}")"
  PAYLOAD_SHA256="${PAYLOAD_SHA256,,}"
  [[ "${PAYLOAD_SHA256}" =~ ^[0-9a-f]{64}$ ]] || die "invalid sha256 in os.img.xz.sha256"

  local actual_sha
  actual_sha="$(sha256sum "${PAYLOAD_PATH}" | awk '{print $1}')"
  [[ "${PAYLOAD_SHA256}" == "${actual_sha}" ]] || die "payload SHA mismatch (expected ${PAYLOAD_SHA256}, got ${actual_sha})"
}

load_selected_payload_airgap_metadata() {
  [[ -f "${PAYLOAD_META}" ]] || die "selected OS payload metadata missing: ${PAYLOAD_META}"
  # shellcheck disable=SC1090
  source "${PAYLOAD_META}"

  REQUIRED_AIRGAP_PLATFORM_CONTRACT_DIGEST="${OURBOX_PLATFORM_CONTRACT_DIGEST:-}"
  [[ "${REQUIRED_AIRGAP_PLATFORM_CONTRACT_DIGEST}" =~ ^sha256:[0-9a-f]{64}$ ]] || die "selected OS payload is missing a valid OURBOX_PLATFORM_CONTRACT_DIGEST in ${PAYLOAD_META}"

  BAKED_AIRGAP_PLATFORM_REF="${OURBOX_AIRGAP_PLATFORM_REF:-}"
  [[ -n "${BAKED_AIRGAP_PLATFORM_REF}" ]] || die "selected OS payload is missing OURBOX_AIRGAP_PLATFORM_REF in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_DIGEST="${OURBOX_AIRGAP_PLATFORM_DIGEST:-}"
  [[ "${BAKED_AIRGAP_PLATFORM_DIGEST}" =~ ^sha256:[0-9a-f]{64}$ ]] || die "selected OS payload is missing a valid OURBOX_AIRGAP_PLATFORM_DIGEST in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_SOURCE="${OURBOX_AIRGAP_PLATFORM_SOURCE:-}"
  [[ -n "${BAKED_AIRGAP_PLATFORM_SOURCE}" ]] || die "selected OS payload is missing OURBOX_AIRGAP_PLATFORM_SOURCE in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_REVISION="${OURBOX_AIRGAP_PLATFORM_REVISION:-}"
  [[ -n "${BAKED_AIRGAP_PLATFORM_REVISION}" ]] || die "selected OS payload is missing OURBOX_AIRGAP_PLATFORM_REVISION in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_VERSION="${OURBOX_AIRGAP_PLATFORM_VERSION:-}"
  [[ -n "${BAKED_AIRGAP_PLATFORM_VERSION}" ]] || die "selected OS payload is missing OURBOX_AIRGAP_PLATFORM_VERSION in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_CREATED="${OURBOX_AIRGAP_PLATFORM_CREATED:-}"
  [[ -n "${BAKED_AIRGAP_PLATFORM_CREATED}" ]] || die "selected OS payload is missing OURBOX_AIRGAP_PLATFORM_CREATED in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_ARCH="${OURBOX_AIRGAP_PLATFORM_ARCH:-}"
  [[ "${BAKED_AIRGAP_PLATFORM_ARCH}" == "arm64" ]] || die "selected OS payload airgap arch mismatch: expected arm64, got ${BAKED_AIRGAP_PLATFORM_ARCH:-unknown}"
  BAKED_AIRGAP_PLATFORM_PROFILE="${OURBOX_AIRGAP_PLATFORM_PROFILE:-}"
  [[ -n "${BAKED_AIRGAP_PLATFORM_PROFILE}" ]] || die "selected OS payload is missing OURBOX_AIRGAP_PLATFORM_PROFILE in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_K3S_VERSION="${OURBOX_AIRGAP_PLATFORM_K3S_VERSION:-}"
  [[ -n "${BAKED_AIRGAP_PLATFORM_K3S_VERSION}" ]] || die "selected OS payload is missing OURBOX_AIRGAP_PLATFORM_K3S_VERSION in ${PAYLOAD_META}"
  BAKED_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256="${OURBOX_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256:-}"
  [[ "${BAKED_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256}" =~ ^[0-9a-f]{64}$ ]] || die "selected OS payload is missing a valid OURBOX_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256 in ${PAYLOAD_META}"
}

