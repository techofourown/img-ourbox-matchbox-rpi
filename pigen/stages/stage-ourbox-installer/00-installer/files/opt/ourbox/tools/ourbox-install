#!/usr/bin/env bash
set -euo pipefail

# shellcheck disable=SC1091
source /opt/ourbox/tools/lib.sh

INSTALLER_LOG="/run/ourbox-installer.log"
if command -v tee >/dev/null 2>&1; then
  exec > >(tee -a "${INSTALLER_LOG}") 2>&1
fi

need_cmd xz
need_cmd xzcat
need_cmd sha256sum
need_cmd dd
need_cmd lsblk
need_cmd readlink
need_cmd findmnt
need_cmd blkid
need_cmd partprobe
need_cmd wipefs
need_cmd blockdev
need_cmd parted
need_cmd mkfs.ext4
need_cmd mount
need_cmd umount
need_cmd mountpoint
need_cmd find
need_cmd openssl
need_cmd sync
need_cmd curl
need_cmd tar
need_cmd ip
need_cmd sort
need_cmd udevadm

DATA_CHECK_MP="/run/ourbox-installer/data-check"
SYS_BOOT_MP="/run/ourbox-installer/sys-boot"
SYS_ROOT_MP="/run/ourbox-installer/sys-root"
PAYLOAD_DIR="/opt/ourbox/installer/cache/payload"
CATALOG_DIR="/opt/ourbox/installer/cache/catalog"
INSTALL_DEFAULTS_DIR="/opt/ourbox/installer/cache/install-defaults"
INSTALL_DEFAULTS_EXTRACT_DIR="/opt/ourbox/installer/cache/install-defaults-extracted"
DEFAULTS_ENV="/opt/ourbox/installer/defaults.env"
OVERRIDE_ENV="/boot/firmware/ourbox-installer.env"

OS_REPO=""
OS_TARGET=""
OS_CHANNEL=""
OS_DEFAULT_REF=""
OS_CATALOG_ENABLED=1
OS_CATALOG_TAG=""
OS_ARTIFACT_TYPE=""
OS_ORAS_VERSION=""
OS_REF=""
OS_REGISTRY_USERNAME=""
OS_REGISTRY_PASSWORD=""
INSTALL_DEFAULTS_REF=""
INSTALLER_ID=""
CHANNEL_STABLE_TAG=""
CHANNEL_BETA_TAG=""
CHANNEL_NIGHTLY_TAG=""
CHANNEL_EXP_LABS_TAG=""
INSTALL_DEFAULTS_PROFILE=""
SELECTED_REF=""
PAYLOAD_PATH=""
PAYLOAD_SHA256=""
PAYLOAD_META=""
OURBOX_INSTALLER_SSH_TEARDOWN_ON_COMPLETE="0"
INSTALLER_VERSION=""
INSTALLER_GIT_HASH=""
INSTALL_SELECTION_SOURCE=""
RELEASE_CHANNEL=""
DEFAULT_SELECTION_SOURCE=""
DEFAULT_RELEASE_CHANNEL=""
PULL_REF=""
OS_ARTIFACT_SOURCE="registry"
OS_ARTIFACT_REF=""
OS_ARTIFACT_DIGEST=""
IDENTITY_USERNAME="ourbox"
IDENTITY_PASSWORD_HASH=""
# shellcheck disable=SC2034  # consumed by sourced storage-flow helper
MATCHBOX_DATA_CHECK_MP="${DATA_CHECK_MP}"

# shellcheck disable=SC1091
source /opt/ourbox/tools/matchbox-storage-flow.sh
# shellcheck disable=SC1091
source /opt/ourbox/tools/installer-selection-resolver.sh

cleanup_mounts() {
  matchbox_cleanup_data_check_mp
  if mountpoint -q "${SYS_BOOT_MP}"; then
    umount "${SYS_BOOT_MP}" >/dev/null 2>&1 || true
  fi
  if mountpoint -q "${SYS_ROOT_MP}"; then
    umount "${SYS_ROOT_MP}" >/dev/null 2>&1 || true
  fi
}

cleanup_temp() {
  rm -rf "${PAYLOAD_DIR}" "${CATALOG_DIR}" "${INSTALL_DEFAULTS_DIR}" "${INSTALL_DEFAULTS_EXTRACT_DIR}"
}

finalize() {
  local rc=$?
  trap - EXIT
  cleanup_mounts

  echo
  if [[ "${rc}" -eq 0 ]]; then
    log "Installer finished (success). Powering off now."
    sync || true
    systemctl poweroff || /sbin/poweroff || true
    exit 0
  fi

  log "ERROR: Installer failed (rc=${rc})."
  log "Dropping to an interactive shell for debugging."
  log "Installer log is available at ${INSTALLER_LOG}"
  log "When you're done, type: poweroff"

  exec /bin/bash -l
}
trap finalize EXIT

confirm_exact_answer() {
  local expected="$1"
  local prompt="$2"
  local ans=""

  read -r -p "${prompt} " ans
  [[ "${ans}" == "${expected}" ]]
}

prompt_confirm_exact() {
  local expected="$1"
  local prompt="$2"
  confirm_exact_answer "${expected}" "${prompt}" \
    || die "confirmation did not match (expected: ${expected})"
}

prompt_nonempty() {
  local prompt="$1"
  local default="${2:-}"
  local ans=""

  if [[ -n "${default}" ]]; then
    read -r -p "${prompt} [${default}]: " ans
    ans="${ans:-${default}}"
  else
    read -r -p "${prompt}: " ans
  fi

  [[ -n "${ans}" ]] || die "value required"
  printf '%s\n' "${ans}"
}

prompt_password_hash() {
  local pw1="" pw2=""

  while true; do
    read -r -s -p "Password: " pw1; echo >&2
    read -r -s -p "Confirm:  " pw2; echo >&2
    [[ -n "${pw1}" ]] || { echo "Password cannot be empty." >&2; continue; }
    [[ "${pw1}" == "${pw2}" ]] || { echo "Passwords did not match. Try again." >&2; continue; }
    printf '%s' "${pw1}" | openssl passwd -6 -stdin
    return 0
  done
}

# shellcheck disable=SC2317  # banner is reached from the interactive main flow
banner() {
  local ip=""

  ip="$(ip route get 10.255.255.255 2>/dev/null | awk '/src/ {print $7; exit}' || true)"
  echo
  echo "=================================================================="
  echo "OurBox Matchbox Installer"
  echo "=================================================================="
  if [[ -n "${ip}" ]]; then
    echo "Network IP    : ${ip}"
  fi
  echo "Installer log : ${INSTALLER_LOG}"
  echo "=================================================================="
  echo
}

show_install_plan() {
  echo "Install summary:"
  echo "  SYSTEM disk : ${MATCHBOX_SYSTEM_DISK}"
  if [[ -n "${MATCHBOX_SYSTEM_DISK_SERIAL}" ]]; then
    echo "  Disk serial : ${MATCHBOX_SYSTEM_DISK_SERIAL}"
  fi
  echo "  DATA disk   : ${MATCHBOX_DATA_DISK}"
  echo "  DATA action : ${MATCHBOX_DATA_ACTION_SUMMARY}"
  if [[ -n "${MATCHBOX_DATA_PART}" ]]; then
    echo "  DATA part   : ${MATCHBOX_DATA_PART}"
  fi
  echo "  OS artifact : ${OS_ARTIFACT_REF}"
  echo "  Payload SHA : ${PAYLOAD_SHA256}"
  echo "  Username    : ${IDENTITY_USERNAME}"
  if [[ "${MATCHBOX_SYSTEM_DISK_WAS_DATA}" == "1" ]]; then
    echo "  Note        : selected SYSTEM disk currently carries OURBOX_DATA and will be cleared"
  fi
  echo
}

show_completion_summary() {
  echo "Handoff summary:"
  echo "  SYSTEM disk : ${MATCHBOX_SYSTEM_DISK}"
  echo "  DATA disk   : ${MATCHBOX_DATA_DISK}"
  echo "  DATA action : ${MATCHBOX_DATA_ACTION_SUMMARY}"
  echo "  OS artifact : ${OS_ARTIFACT_REF}"
  echo "  Payload SHA : ${PAYLOAD_SHA256}"
  echo "  Username    : ${IDENTITY_USERNAME}"
  echo
}

matchbox_partition_path() {
  local disk="$1"
  local part_num="$2"

  if [[ "${disk}" =~ [0-9]$ ]]; then
    printf '%s\n' "${disk}p${part_num}"
  else
    printf '%s\n' "${disk}${part_num}"
  fi
}

normalize_payload_config() {
  OS_REPO="${OS_REPO:-ghcr.io/techofourown/ourbox-matchbox-os}"
  OS_TARGET="${OS_TARGET:-rpi}"
  OS_CHANNEL="${OS_CHANNEL:-stable}"
  OS_DEFAULT_REF="${OS_DEFAULT_REF:-}"
  OS_CATALOG_ENABLED="${OS_CATALOG_ENABLED:-1}"
  OS_CATALOG_TAG="${OS_CATALOG_TAG:-${OS_TARGET}-catalog}"
  OS_ARTIFACT_TYPE="${OS_ARTIFACT_TYPE:-application/vnd.ourbox.matchbox.os-image.v1}"
  OS_ORAS_VERSION="${OS_ORAS_VERSION:-1.3.0}"
  OS_REF="${OS_REF:-}"
  OS_REGISTRY_USERNAME="${OS_REGISTRY_USERNAME:-}"
  OS_REGISTRY_PASSWORD="${OS_REGISTRY_PASSWORD:-}"
  INSTALL_DEFAULTS_REF="${INSTALL_DEFAULTS_REF:-ghcr.io/techofourown/sw-ourbox-os/install-defaults:stable}"
  INSTALLER_ID="${INSTALLER_ID:-matchbox}"
  CHANNEL_STABLE_TAG="${CHANNEL_STABLE_TAG:-${OS_TARGET}-stable}"
  CHANNEL_BETA_TAG="${CHANNEL_BETA_TAG:-${OS_TARGET}-beta}"
  CHANNEL_NIGHTLY_TAG="${CHANNEL_NIGHTLY_TAG:-${OS_TARGET}-nightly}"
  CHANNEL_EXP_LABS_TAG="${CHANNEL_EXP_LABS_TAG:-${OS_TARGET}-exp-labs}"
  OURBOX_INSTALLER_SSH_TEARDOWN_ON_COMPLETE="${OURBOX_INSTALLER_SSH_TEARDOWN_ON_COMPLETE:-0}"
  INSTALLER_VERSION="${INSTALLER_VERSION:-unknown}"
  INSTALLER_GIT_HASH="${INSTALLER_GIT_HASH:-unknown}"
}

teardown_installer_ssh() {
  [[ "${OURBOX_INSTALLER_SSH_TEARDOWN_ON_COMPLETE}" == "1" ]] || {
    log "Installer SSH teardown disabled."
    return 0
  }

  systemctl stop ssh >/dev/null 2>&1 || true
  log "Installer SSH service stopped for this session."
}

load_payload_config() {

  # shellcheck disable=SC1090
  [[ -f "${DEFAULTS_ENV}" ]] && source "${DEFAULTS_ENV}"
  # shellcheck disable=SC1090
  [[ -f "${OVERRIDE_ENV}" ]] && source "${OVERRIDE_ENV}"

  normalize_payload_config
}

load_remote_install_defaults() {
  INSTALL_DEFAULTS_PROFILE=""

  ourbox_selection_load_remote_install_defaults \
    "${INSTALL_DEFAULTS_DIR}" \
    "${INSTALL_DEFAULTS_EXTRACT_DIR}" \
    "${OVERRIDE_ENV}"

  if [[ "${OURBOX_INSTALL_DEFAULTS_SOURCE}" == "remote" ]]; then
    INSTALL_DEFAULTS_PROFILE="${OURBOX_INSTALL_DEFAULTS_PROFILE}"
  fi
}

map_arch() {
  case "$(uname -m)" in
    x86_64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) die "unsupported architecture: $(uname -m)" ;;
  esac
}

ensure_oras() {
  local desired="v${OS_ORAS_VERSION}"
  if command -v oras >/dev/null 2>&1; then
    local current
    current="$(oras version 2>/dev/null | awk '/Version:/ {print $2}' || true)"
    if [[ "${current}" == "${OS_ORAS_VERSION}" || "${current}" == "${desired#v}" ]]; then
      log "ORAS already present (${current})"
      return 0
    fi
    log "ORAS present but not ${OS_ORAS_VERSION}; upgrading"
  else
    log "Installing ORAS ${OS_ORAS_VERSION}"
  fi

  local arch url tmpdir
  arch="$(map_arch)"
  url="https://github.com/oras-project/oras/releases/download/v${OS_ORAS_VERSION}/oras_${OS_ORAS_VERSION}_linux_${arch}.tar.gz"
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "${tmpdir}"' RETURN
  curl -fsSL -o "${tmpdir}/oras.tgz" "${url}"
  tar -C "${tmpdir}" -xzf "${tmpdir}/oras.tgz" oras
  install -m 0755 "${tmpdir}/oras" /usr/local/bin/oras
  trap - RETURN
  rm -rf "${tmpdir}"
  log "ORAS installed: $(oras version 2>/dev/null | tr -d "$(printf '\r')")"
}

maybe_oras_login() {
  if [[ -n "${OS_REGISTRY_USERNAME}" ]]; then
    log "Logging into registry for ${OS_REPO}"
    oras login "$(echo "${OS_REPO}" | cut -d/ -f1)" -u "${OS_REGISTRY_USERNAME}" --password "${OS_REGISTRY_PASSWORD:-}" >/dev/null
  fi
}

ensure_dirs() {
  cleanup_temp
  mkdir -p "${PAYLOAD_DIR}" "${CATALOG_DIR}"
}

wait_for_network() {
  local retries=40
  local ok=0
  for _i in $(seq 1 "${retries}"); do
    if ip -o -4 addr show up scope global | grep -q .; then
      ok=1
      break
    fi
    sleep 0.5
  done
  [[ "${ok}" -eq 1 ]] || die "network not ready (no global IPv4 after ${retries} attempts)"
}

show_default_choice() {
  local ref="$1"
  echo
  if [[ "${OURBOX_INSTALL_DEFAULTS_SOURCE}" == "remote" ]]; then
    echo "Install defaults: remote (${INSTALL_DEFAULTS_REF})"
    echo "Profile        : ${INSTALL_DEFAULTS_PROFILE}"
  else
    echo "Install defaults: baked defaults"
  fi
  echo "Default source : ${DEFAULT_SELECTION_SOURCE:-pending}"
  echo "Default: install '${ref}'"
  echo "Options:"
  echo "  [ENTER] Use default"
  echo "  c       Choose channel (stable/beta/nightly/exp-labs/custom)"
  echo "  l       List from catalog (if available)"
  echo "  r       Enter custom OCI ref (tag or digest)"
  echo "  o       Override OS repo (custom registry/fork)"
  echo "  q       Quit"
  echo
}

ref_from_tag() {
  local tag="$1"
  echo "${OS_REPO}:${tag}"
}

default_payload_ref() {
  ourbox_selection_determine_default_ref "${CATALOG_DIR}/default"
  DEFAULT_SELECTION_SOURCE="${OURBOX_INSTALL_SELECTION_SOURCE}"
  DEFAULT_RELEASE_CHANNEL="${OURBOX_RELEASE_CHANNEL}"
  printf '%s\n' "${OURBOX_SELECTED_REF}"
}

override_repo() {
  local next_repo=""
  read -r -p "Enter OCI repo (e.g., ghcr.io/org/ourbox-matchbox-os): " next_repo
  [[ -n "${next_repo}" ]] || { log "Repository cannot be empty"; return 1; }
  OS_REPO="${next_repo}"

  # A repo override intentionally clears pinned defaults from upstream profile.
  OS_REF=""
  OS_DEFAULT_REF=""

  local next_catalog="${OS_TARGET}-catalog"
  local user_catalog=""
  read -r -p "Catalog tag [${next_catalog}]: " user_catalog
  if [[ -n "${user_catalog}" ]]; then
    OS_CATALOG_TAG="${user_catalog}"
  else
    OS_CATALOG_TAG="${next_catalog}"
  fi

  log "OS repo override set to ${OS_REPO}"
}

choose_channel() {
  echo "Channels:"
  echo "  1) ${CHANNEL_STABLE_TAG} (recommended)"
  echo "  2) ${CHANNEL_BETA_TAG}"
  echo "  3) ${CHANNEL_NIGHTLY_TAG}"
  echo "  4) ${CHANNEL_EXP_LABS_TAG}"
  echo "  5) custom tag name"
  local pick=""
  read -r -p "Select channel [1-5]: " pick
  case "${pick}" in
    1|"")
      SELECTED_REF="$(ref_from_tag "${CHANNEL_STABLE_TAG}")"
      INSTALL_SELECTION_SOURCE="channel-tag"
      RELEASE_CHANNEL="stable"
      ;;
    2)
      SELECTED_REF="$(ref_from_tag "${CHANNEL_BETA_TAG}")"
      INSTALL_SELECTION_SOURCE="channel-tag"
      RELEASE_CHANNEL="beta"
      ;;
    3)
      SELECTED_REF="$(ref_from_tag "${CHANNEL_NIGHTLY_TAG}")"
      INSTALL_SELECTION_SOURCE="channel-tag"
      RELEASE_CHANNEL="nightly"
      ;;
    4)
      SELECTED_REF="$(ref_from_tag "${CHANNEL_EXP_LABS_TAG}")"
      INSTALL_SELECTION_SOURCE="channel-tag"
      RELEASE_CHANNEL="exp-labs"
      ;;
    5)
      local ch=""
      read -r -p "Enter tag: " ch
      [[ -n "${ch}" ]] || die "tag cannot be empty"
      SELECTED_REF="$(ref_from_tag "${ch}")"
      INSTALL_SELECTION_SOURCE="channel-tag"
      RELEASE_CHANNEL=""
      ;;
    *) log "Invalid choice, using default";;
  esac
}

select_from_catalog() {
  CATALOG_REF=""
  ourbox_selection_pull_catalog "${CATALOG_DIR}" || { log "Catalog unavailable; skipping list."; return 1; }
  CATALOG_REF="${OURBOX_CATALOG_REF}"
  local catalog="${CATALOG_DIR}/catalog.tsv"

  mapfile -t entries < <(ourbox_selection_catalog_entries "${catalog}")
  if [[ "${#entries[@]}" -eq 0 ]]; then
    log "Catalog pulled (${CATALOG_REF}) but contained no entries."
    return 1
  fi

  echo
  echo "Catalog entries (${CATALOG_REF}):"
  local i=1
  for line in "${entries[@]}"; do
    IFS=$'\t' read -r channel tag created version contract pinned_ref <<<"${line}"
    printf "  %d) %-12s %-30s %s %s %s\n" "${i}" "${channel}" "${tag}" "${version}" "${created}" "${contract}"
    i=$((i+1))
  done

  local pick=""
  read -r -p "Choose entry [1-${#entries[@]}] (or ENTER to cancel): " pick
  [[ -z "${pick}" ]] && return 1
  [[ "${pick}" =~ ^[0-9]+$ ]] || { log "Invalid selection"; return 1; }
  if (( pick < 1 || pick > ${#entries[@]} )); then
    log "Selection out of range"
    return 1
  fi
  local chosen="${entries[$((pick-1))]}"
  IFS=$'\t' read -r channel tag created version contract pinned_ref <<<"${chosen}"
  SELECTED_REF="${pinned_ref}"
  INSTALL_SELECTION_SOURCE="catalog"
  RELEASE_CHANNEL="${channel}"
  log "Selected ${SELECTED_REF} (channel=${channel}, version=${version}, contract=${contract})"
  return 0
}

select_payload_ref() {
  SELECTED_REF=""
  INSTALL_SELECTION_SOURCE=""
  RELEASE_CHANNEL=""

  while [[ -z "${SELECTED_REF}" ]]; do
    local default_ref
    default_ref="$(default_payload_ref)"
    show_default_choice "${default_ref}"
    local choice=""
    read -r -p "Choice: " choice
    case "${choice}" in
      "" )
        SELECTED_REF="${default_ref}"
        INSTALL_SELECTION_SOURCE="${DEFAULT_SELECTION_SOURCE}"
        RELEASE_CHANNEL="${DEFAULT_RELEASE_CHANNEL}"
        ;;
      c ) choose_channel ;;
      l ) select_from_catalog || true ;;
      r )
        read -r -p "Enter full OCI ref (e.g., repo:tag or repo@sha256:...): " ref
        [[ -n "${ref}" ]] || { log "Ref cannot be empty"; continue; }
        SELECTED_REF="${ref}"
        INSTALL_SELECTION_SOURCE="operator-override"
        RELEASE_CHANNEL=""
        ;;
      o ) override_repo || true ;;
      q|Q ) die "Install aborted by user" ;;
      * ) log "Unknown option" ;;
    esac
  done
}

parse_sha256_file() {
  local file="$1"
  awk 'NF>=1 {print $1; exit}' "${file}"
}

finalize_selected_payload_ref() {
  ourbox_selection_finalize_registry_ref "${SELECTED_REF}"
  PULL_REF="${OURBOX_PULL_REF}"
  OS_ARTIFACT_SOURCE="${OURBOX_OS_ARTIFACT_SOURCE}"
  OS_ARTIFACT_REF="${OURBOX_OS_ARTIFACT_REF}"
  OS_ARTIFACT_DIGEST="${OURBOX_OS_ARTIFACT_DIGEST}"
}

pull_payload() {
  rm -rf "${PAYLOAD_DIR}"
  mkdir -p "${PAYLOAD_DIR}"
  log "Pulling OS payload: ${PULL_REF}"
  oras pull "${PULL_REF}" -o "${PAYLOAD_DIR}"

  PAYLOAD_PATH="${PAYLOAD_DIR}/os.img.xz"
  [[ -f "${PAYLOAD_PATH}" ]] || die "oras pull succeeded but os.img.xz missing from payload"

  PAYLOAD_META="${PAYLOAD_DIR}/os.meta.env"

  local sha_file="${PAYLOAD_DIR}/os.img.xz.sha256"
  [[ -f "${sha_file}" ]] || die "payload missing os.img.xz.sha256"
  PAYLOAD_SHA256="$(parse_sha256_file "${sha_file}")"
  PAYLOAD_SHA256="${PAYLOAD_SHA256,,}"
  [[ "${PAYLOAD_SHA256}" =~ ^[0-9a-f]{64}$ ]] || die "invalid sha256 in os.img.xz.sha256"

  local actual_sha
  actual_sha="$(sha256sum "${PAYLOAD_PATH}" | awk '{print $1}')"
  [[ "${PAYLOAD_SHA256}" == "${actual_sha}" ]] || die "payload SHA mismatch (expected ${PAYLOAD_SHA256}, got ${actual_sha})"
}

show_payload_metadata() {
  echo
  if [[ "${OURBOX_INSTALL_DEFAULTS_SOURCE}" == "remote" ]]; then
    echo "Install defaults : remote (${INSTALL_DEFAULTS_REF})"
    echo "Defaults profile : ${INSTALL_DEFAULTS_PROFILE}"
  else
    echo "Install defaults : baked defaults"
  fi
  echo "Selection source: ${INSTALL_SELECTION_SOURCE:-unknown}"
  if [[ -n "${RELEASE_CHANNEL}" ]]; then
    echo "Release channel : ${RELEASE_CHANNEL}"
  fi
  echo "Payload source  : ${SELECTED_REF}"
  echo "Pull ref        : ${PULL_REF}"
  echo "Artifact digest : ${OS_ARTIFACT_DIGEST}"
  echo "Payload sha256  : ${PAYLOAD_SHA256}"
  if [[ -f "${PAYLOAD_META}" ]]; then
    echo "Payload metadata:"
    while IFS='=' read -r k v; do
      [[ -z "${k}" ]] && continue
      printf "  %s=%s\n" "${k}" "${v}"
    done < "${PAYLOAD_META}"
  else
    echo "Payload metadata: (os.meta.env not present)"
  fi
  echo
}

write_install_provenance() {
  local sys_disk="$1"
  local root_part=""
  local release_file=""

  root_part="$(matchbox_partition_path "${sys_disk}" 2)"
  install -d -m 0755 "${SYS_ROOT_MP}"
  if mountpoint -q "${SYS_ROOT_MP}"; then
    umount "${SYS_ROOT_MP}" >/dev/null 2>&1 || true
  fi

  mount "${root_part}" "${SYS_ROOT_MP}"
  release_file="${SYS_ROOT_MP}/etc/ourbox/release"
  [[ -f "${release_file}" ]] || die "installed release metadata missing: ${release_file}"

  cat >> "${release_file}" <<EOF
OURBOX_INSTALLER_ID=${INSTALLER_ID:-matchbox}
OURBOX_INSTALLER_VERSION=${INSTALLER_VERSION:-unknown}
OURBOX_INSTALLER_GIT_HASH=${INSTALLER_GIT_HASH:-unknown}
OURBOX_OS_ARTIFACT_SOURCE=${OS_ARTIFACT_SOURCE:-unknown}
OURBOX_OS_ARTIFACT_REF=${OS_ARTIFACT_REF:-unknown}
OURBOX_OS_ARTIFACT_DIGEST=${OS_ARTIFACT_DIGEST:-unknown}
OURBOX_OS_IMAGE_SHA256=${PAYLOAD_SHA256:-unknown}
OURBOX_INSTALL_DEFAULTS_SOURCE=${OURBOX_INSTALL_DEFAULTS_SOURCE:-baked}
OURBOX_INSTALL_DEFAULTS_REF=${INSTALL_DEFAULTS_REF:-}
OURBOX_INSTALL_SELECTION_SOURCE=${INSTALL_SELECTION_SOURCE:-unknown}
OURBOX_RELEASE_CHANNEL=${RELEASE_CHANNEL:-}
EOF
  sync
  umount "${SYS_ROOT_MP}"
  log "Install provenance appended to /etc/ourbox/release"
}

main() {
  local root_src root_real root_parent
  local disks=()

  banner
  echo "Step 1 of 4: Resolve OS artifact"
  echo "Checking baked defaults, optional remote install-defaults, and the selected OS payload."
  echo

  load_payload_config
  ensure_dirs
  wait_for_network
  ensure_oras
  maybe_oras_login
  load_remote_install_defaults
  maybe_oras_login
  select_payload_ref
  finalize_selected_payload_ref
  pull_payload

  log "Verifying compressed payload integrity"
  xz -t "${PAYLOAD_PATH}"

  banner
  show_payload_metadata

  banner
  echo "Step 2 of 4: Review storage plan"
  echo "Matchbox requires exactly two NVMe disks: one SYSTEM disk and one DATA disk."
  echo

  log "Running hard safety preflight"
  root_src="$(findmnt -nr -o SOURCE / 2>/dev/null || true)"
  root_real="$(readlink -f "${root_src}" 2>/dev/null || echo "${root_src}")"
  root_parent="$(lsblk -no PKNAME "${root_real}" 2>/dev/null || true)"
  if [[ -n "${root_parent}" ]]; then
    root_real="/dev/${root_parent}"
  fi
  [[ "${root_real}" != /dev/nvme* ]] || die "root filesystem is on NVMe (${root_real}); boot installer from SD/USB"

  udevadm settle --timeout=10 || true
  log "Waiting for exactly 2 NVMe disks to enumerate"
  for _i in $(seq 1 40); do
    mapfile -t disks < <(matchbox_nvme_disks)
    [[ "${#disks[@]}" -eq 2 ]] && break
    sleep 0.5
  done

  if [[ "${#disks[@]}" -ne 2 ]]; then
    lsblk -o NAME,SIZE,MODEL,SERIAL,TYPE,FSTYPE,LABEL,MOUNTPOINTS || true
    die "expected exactly 2 NVMe disks, found ${#disks[@]}"
  fi

  if lsblk -nr -o MOUNTPOINT "${disks[@]}" | awk 'NF && $0 != "" {found=1} END{exit !found}'; then
    lsblk -o NAME,FSTYPE,LABEL,MOUNTPOINTS "${disks[@]}" || true
    die "NVMe partitions are mounted; unmount and retry"
  fi

  log "Preparing storage layout"
  matchbox_prepare_storage_layout "${disks[@]}"

  banner
  echo "Step 3 of 4: Set identity for the installed system"
  echo "(You can change the username or password later on the installed system.)"
  echo

  IDENTITY_USERNAME="$(prompt_nonempty "Username for first boot" "ourbox")"
  echo
  echo "Set the login password for ${IDENTITY_USERNAME}:"
  IDENTITY_PASSWORD_HASH="$(prompt_password_hash)"

  banner
  echo "Step 4 of 4: Confirm and flash"
  echo
  show_install_plan
  echo "WARNING: ALL DATA ON ${MATCHBOX_SYSTEM_DISK} WILL BE PERMANENTLY ERASED."
  case "${MATCHBOX_DATA_ACTION}" in
    init-data|erase-data)
      echo "WARNING: ${MATCHBOX_DATA_DISK} will also be erased and recreated as LABEL=OURBOX_DATA."
      ;;
    reset-bootstrap)
      echo "DATA on ${MATCHBOX_DATA_DISK} will be preserved, but bootstrap.done will be removed."
      ;;
    keep-data)
      echo "DATA on ${MATCHBOX_DATA_DISK} will be preserved."
      ;;
  esac
  echo
  prompt_confirm_exact "INSTALL" "Type INSTALL to begin (or Ctrl-C to abort):"

  matchbox_apply_storage_layout

  log "Flashing payload to SYSTEM"
  xzcat "${PAYLOAD_PATH}" | dd of="${MATCHBOX_SYSTEM_DISK}" bs=4M conv=fsync status=progress
  sync

  partprobe "${MATCHBOX_SYSTEM_DISK}" || true
  lsblk -f "${MATCHBOX_SYSTEM_DISK}"

  mkdir -p "${SYS_BOOT_MP}"
  if mountpoint -q "${SYS_BOOT_MP}"; then
    umount "${SYS_BOOT_MP}" >/dev/null 2>&1 || true
  fi

  mount "$(matchbox_partition_path "${MATCHBOX_SYSTEM_DISK}" 1)" "${SYS_BOOT_MP}"
  printf '%s:%s\n' "${IDENTITY_USERNAME}" "${IDENTITY_PASSWORD_HASH}" > "${SYS_BOOT_MP}/userconf.txt"
  sync
  umount "${SYS_BOOT_MP}"
  log "userconf written"

  write_install_provenance "${MATCHBOX_SYSTEM_DISK}"

  teardown_installer_ssh

  echo
  show_completion_summary
  echo "Remove installer media"
  echo "Boot from NVMe"
}

main "$@"
