pull_selected_airgap_platform_bundle() {
  rm -rf "${AIRGAP_PULL_DIR}" "${AIRGAP_OVERRIDE_DIR}"

  if [[ "${OURBOX_AIRGAP_PLATFORM_REF}" == "${BAKED_AIRGAP_PLATFORM_REF}" ]]; then
    OURBOX_AIRGAP_PLATFORM_ARTIFACT_SOURCE="baked"
    OURBOX_AIRGAP_PLATFORM_SOURCE="${BAKED_AIRGAP_PLATFORM_SOURCE}"
    OURBOX_AIRGAP_PLATFORM_REVISION="${BAKED_AIRGAP_PLATFORM_REVISION}"
    OURBOX_AIRGAP_PLATFORM_VERSION="${BAKED_AIRGAP_PLATFORM_VERSION}"
    OURBOX_AIRGAP_PLATFORM_CREATED="${BAKED_AIRGAP_PLATFORM_CREATED}"
    OURBOX_AIRGAP_PLATFORM_ARCH="${BAKED_AIRGAP_PLATFORM_ARCH}"
    OURBOX_AIRGAP_PLATFORM_PROFILE="${BAKED_AIRGAP_PLATFORM_PROFILE}"
    OURBOX_AIRGAP_PLATFORM_K3S_VERSION="${BAKED_AIRGAP_PLATFORM_K3S_VERSION}"
    OURBOX_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256="${BAKED_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256}"
    return 0
  fi

  mkdir -p "${AIRGAP_PULL_DIR}" "${AIRGAP_OVERRIDE_DIR}"
  maybe_airgap_oras_login
  log "Pulling airgap-platform bundle: ${AIRGAP_PLATFORM_PULL_REF}"
  oras pull "${AIRGAP_PLATFORM_PULL_REF}" -o "${AIRGAP_PULL_DIR}"

  local tarball="${AIRGAP_PULL_DIR}/dist/airgap-platform.tar.gz"
  [[ -f "${tarball}" ]] || die "oras pull succeeded but airgap-platform.tar.gz missing from ${AIRGAP_PULL_DIR}"

  tar -xzf "${tarball}" -C "${AIRGAP_OVERRIDE_DIR}"
  ourbox_airgap_platform_selection_validate_extracted_bundle "${AIRGAP_OVERRIDE_DIR}" "${REQUIRED_AIRGAP_PLATFORM_CONTRACT_DIGEST}" "arm64"
  OURBOX_AIRGAP_PLATFORM_ARTIFACT_SOURCE="registry"
}

show_airgap_platform_metadata() {
  echo
  echo "Airgap platform:"
  echo "  Selection source: ${OURBOX_AIRGAP_PLATFORM_SELECTION_SOURCE:-unknown}"
  if [[ -n "${OURBOX_AIRGAP_PLATFORM_RELEASE_CHANNEL}" ]]; then
    echo "  Release channel : ${OURBOX_AIRGAP_PLATFORM_RELEASE_CHANNEL}"
  fi
  echo "  Artifact source : ${OURBOX_AIRGAP_PLATFORM_ARTIFACT_SOURCE:-unknown}"
  echo "  Artifact ref    : ${OURBOX_AIRGAP_PLATFORM_REF:-unknown}"
  echo "  Artifact digest : ${OURBOX_AIRGAP_PLATFORM_DIGEST:-unknown}"
  echo "  Upstream source : ${OURBOX_AIRGAP_PLATFORM_SOURCE:-unknown}"
  echo "  Revision        : ${OURBOX_AIRGAP_PLATFORM_REVISION:-unknown}"
  echo "  Version         : ${OURBOX_AIRGAP_PLATFORM_VERSION:-unknown}"
  echo "  Created         : ${OURBOX_AIRGAP_PLATFORM_CREATED:-unknown}"
  echo "  Arch            : ${OURBOX_AIRGAP_PLATFORM_ARCH:-unknown}"
  echo "  Profile         : ${OURBOX_AIRGAP_PLATFORM_PROFILE:-unknown}"
  echo "  K3s version     : ${OURBOX_AIRGAP_PLATFORM_K3S_VERSION:-unknown}"
  echo "  Images lock sha : ${OURBOX_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256:-unknown}"
  echo
}

show_payload_metadata() {
  echo
  if [[ "${OURBOX_INSTALL_DEFAULTS_SOURCE}" == "remote" ]]; then
    echo "Install defaults : remote (${INSTALL_DEFAULTS_REF})"
    echo "Defaults profile : ${INSTALL_DEFAULTS_PROFILE}"
  else
    echo "Install defaults : baked defaults"
  fi
  echo "Selection source: ${INSTALL_SELECTION_SOURCE:-unknown}"
  if [[ -n "${RELEASE_CHANNEL}" ]]; then
    echo "Release channel : ${RELEASE_CHANNEL}"
  fi
  echo "Payload source  : ${SELECTED_REF}"
  echo "Pull ref        : ${PULL_REF}"
  echo "Artifact digest : ${OS_ARTIFACT_DIGEST}"
  echo "Payload sha256  : ${PAYLOAD_SHA256}"
  if [[ -f "${PAYLOAD_META}" ]]; then
    echo "Payload metadata:"
    while IFS='=' read -r k v; do
      [[ -z "${k}" ]] && continue
      printf "  %s=%s\n" "${k}" "${v}"
    done < "${PAYLOAD_META}"
  else
    echo "Payload metadata: (os.meta.env not present)"
  fi
  echo
}

overlay_selected_airgap_platform_into_mounted_root() {
  [[ "${OURBOX_AIRGAP_PLATFORM_ARTIFACT_SOURCE:-baked}" == "registry" ]] || return 0

  local target_airgap="${SYS_ROOT_MP}/opt/ourbox/airgap"
  local target_platform="${target_airgap}/platform"

  [[ -d "${AIRGAP_OVERRIDE_DIR}/k3s" ]] || die "airgap override missing k3s directory: ${AIRGAP_OVERRIDE_DIR}/k3s"
  [[ -d "${AIRGAP_OVERRIDE_DIR}/platform/images" ]] || die "airgap override missing platform/images directory: ${AIRGAP_OVERRIDE_DIR}/platform/images"
  [[ -f "${AIRGAP_OVERRIDE_DIR}/platform/images.lock.json" ]] || die "airgap override missing platform/images.lock.json"
  [[ -f "${AIRGAP_OVERRIDE_DIR}/platform/profile.env" ]] || die "airgap override missing platform/profile.env"
  [[ -f "${AIRGAP_OVERRIDE_DIR}/manifest.env" ]] || die "airgap override missing manifest.env"

  install -d -m 0755 "${target_airgap}" "${target_platform}"
  rm -rf "${target_airgap}/k3s" "${target_platform}/images"
  cp -a "${AIRGAP_OVERRIDE_DIR}/k3s" "${target_airgap}/k3s"
  cp -a "${AIRGAP_OVERRIDE_DIR}/platform/images" "${target_platform}/images"
  cp -f "${AIRGAP_OVERRIDE_DIR}/platform/images.lock.json" "${target_platform}/images.lock.json"
  cp -f "${AIRGAP_OVERRIDE_DIR}/platform/profile.env" "${target_platform}/profile.env"
  cp -f "${AIRGAP_OVERRIDE_DIR}/manifest.env" "${target_airgap}/manifest.env"
  log "Applied airgap-platform override into installed rootfs"
}

write_install_provenance() {
  local sys_disk="$1"
  local root_part=""
  local release_file=""

  root_part="$(matchbox_partition_path "${sys_disk}" 2)"
  install -d -m 0755 "${SYS_ROOT_MP}"
  if mountpoint -q "${SYS_ROOT_MP}"; then
    umount "${SYS_ROOT_MP}" >/dev/null 2>&1 || true
  fi

  mount "${root_part}" "${SYS_ROOT_MP}"
  overlay_selected_airgap_platform_into_mounted_root
  release_file="${SYS_ROOT_MP}/etc/ourbox/release"
  [[ -f "${release_file}" ]] || die "installed release metadata missing: ${release_file}"

  cat >> "${release_file}" <<EOF
OURBOX_INSTALLER_ID=${INSTALLER_ID:-matchbox}
OURBOX_INSTALLER_VERSION=${INSTALLER_VERSION:-unknown}
OURBOX_INSTALLER_GIT_HASH=${INSTALLER_GIT_HASH:-unknown}
OURBOX_OS_ARTIFACT_SOURCE=${OS_ARTIFACT_SOURCE:-unknown}
OURBOX_OS_ARTIFACT_REF=${OS_ARTIFACT_REF:-unknown}
OURBOX_OS_ARTIFACT_DIGEST=${OS_ARTIFACT_DIGEST:-unknown}
OURBOX_OS_IMAGE_SHA256=${PAYLOAD_SHA256:-unknown}
OURBOX_INSTALL_DEFAULTS_SOURCE=${OURBOX_INSTALL_DEFAULTS_SOURCE:-baked}
OURBOX_INSTALL_DEFAULTS_REF=${INSTALL_DEFAULTS_REF:-}
OURBOX_INSTALL_SELECTION_SOURCE=${INSTALL_SELECTION_SOURCE:-unknown}
OURBOX_RELEASE_CHANNEL=${RELEASE_CHANNEL:-}
OURBOX_AIRGAP_PLATFORM_SOURCE=${OURBOX_AIRGAP_PLATFORM_SOURCE:-unknown}
OURBOX_AIRGAP_PLATFORM_REVISION=${OURBOX_AIRGAP_PLATFORM_REVISION:-unknown}
OURBOX_AIRGAP_PLATFORM_VERSION=${OURBOX_AIRGAP_PLATFORM_VERSION:-unknown}
OURBOX_AIRGAP_PLATFORM_CREATED=${OURBOX_AIRGAP_PLATFORM_CREATED:-unknown}
OURBOX_AIRGAP_PLATFORM_ARCH=${OURBOX_AIRGAP_PLATFORM_ARCH:-unknown}
OURBOX_AIRGAP_PLATFORM_PROFILE=${OURBOX_AIRGAP_PLATFORM_PROFILE:-unknown}
OURBOX_AIRGAP_PLATFORM_K3S_VERSION=${OURBOX_AIRGAP_PLATFORM_K3S_VERSION:-unknown}
OURBOX_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256=${OURBOX_AIRGAP_PLATFORM_IMAGES_LOCK_SHA256:-unknown}
OURBOX_AIRGAP_PLATFORM_ARTIFACT_SOURCE=${OURBOX_AIRGAP_PLATFORM_ARTIFACT_SOURCE:-unknown}
OURBOX_AIRGAP_PLATFORM_REF=${OURBOX_AIRGAP_PLATFORM_REF:-unknown}
OURBOX_AIRGAP_PLATFORM_DIGEST=${OURBOX_AIRGAP_PLATFORM_DIGEST:-unknown}
OURBOX_AIRGAP_PLATFORM_SELECTION_SOURCE=${OURBOX_AIRGAP_PLATFORM_SELECTION_SOURCE:-unknown}
OURBOX_AIRGAP_PLATFORM_RELEASE_CHANNEL=${OURBOX_AIRGAP_PLATFORM_RELEASE_CHANNEL:-}
EOF
  sync
  umount "${SYS_ROOT_MP}"
  log "Install provenance appended to /etc/ourbox/release"
}

main() {
  local root_src root_real root_parent
  local disks=()

  banner
  echo "Step 1 of 5: Resolve OS artifact"
  echo "Checking baked defaults, optional remote install-defaults, and the selected OS payload."
  echo

  load_payload_config
  ensure_dirs
  wait_for_network
  ensure_oras
  maybe_oras_login
  load_remote_install_defaults
  maybe_oras_login
  select_payload_ref
  finalize_selected_payload_ref
  pull_payload

  log "Verifying compressed payload integrity"
  xz -t "${PAYLOAD_PATH}"
  load_selected_payload_airgap_metadata

  banner
  show_payload_metadata

  banner
  echo "Step 2 of 5: Resolve airgap-platform bundle"
  echo "Browsing contract-matching app bundles after OS selection."
  echo
  select_airgap_platform_ref
  finalize_selected_airgap_platform_ref
  pull_selected_airgap_platform_bundle
  show_airgap_platform_metadata

  banner
  echo "Step 3 of 5: Review storage plan"
  echo "Matchbox requires exactly two NVMe disks: one SYSTEM disk and one DATA disk."
  echo

  log "Running hard safety preflight"
  root_src="$(findmnt -nr -o SOURCE / 2>/dev/null || true)"
  root_real="$(readlink -f "${root_src}" 2>/dev/null || echo "${root_src}")"
  root_parent="$(lsblk -no PKNAME "${root_real}" 2>/dev/null || true)"
  if [[ -n "${root_parent}" ]]; then
    root_real="/dev/${root_parent}"
  fi
  [[ "${root_real}" != /dev/nvme* ]] || die "root filesystem is on NVMe (${root_real}); boot installer from SD/USB"

  udevadm settle --timeout=10 || true
  log "Waiting for exactly 2 NVMe disks to enumerate"
  for _i in $(seq 1 40); do
    mapfile -t disks < <(matchbox_nvme_disks)
    [[ "${#disks[@]}" -eq 2 ]] && break
    sleep 0.5
  done

  if [[ "${#disks[@]}" -ne 2 ]]; then
    lsblk -o NAME,SIZE,MODEL,SERIAL,TYPE,FSTYPE,LABEL,MOUNTPOINTS || true
    die "expected exactly 2 NVMe disks, found ${#disks[@]}"
  fi

  if lsblk -nr -o MOUNTPOINT "${disks[@]}" | awk 'NF && $0 != "" {found=1} END{exit !found}'; then
    lsblk -o NAME,FSTYPE,LABEL,MOUNTPOINTS "${disks[@]}" || true
    die "NVMe partitions are mounted; unmount and retry"
  fi

  log "Preparing storage layout"
  matchbox_prepare_storage_layout "${disks[@]}"

  banner
  echo "Step 4 of 5: Set identity for the installed system"
  echo "(You can change the username or password later on the installed system.)"
  echo

  IDENTITY_USERNAME="$(prompt_nonempty "Username for first boot" "ourbox")"
  echo
  echo "Set the login password for ${IDENTITY_USERNAME}:"
  IDENTITY_PASSWORD_HASH="$(prompt_password_hash)"

  banner
  echo "Step 5 of 5: Confirm and flash"
  echo
  show_install_plan
  echo "WARNING: ALL DATA ON ${MATCHBOX_SYSTEM_DISK} WILL BE PERMANENTLY ERASED."
  case "${MATCHBOX_DATA_ACTION}" in
    init-data|erase-data)
      echo "WARNING: ${MATCHBOX_DATA_DISK} will also be erased and recreated as LABEL=OURBOX_DATA."
      ;;
    reset-bootstrap)
      echo "DATA on ${MATCHBOX_DATA_DISK} will be preserved, but bootstrap.done will be removed."
      ;;
    keep-data)
      echo "DATA on ${MATCHBOX_DATA_DISK} will be preserved."
      ;;
  esac
  echo
  prompt_confirm_exact "INSTALL" "Type INSTALL to begin (or Ctrl-C to abort):"

  matchbox_apply_storage_layout

  log "Flashing payload to SYSTEM"
  xzcat "${PAYLOAD_PATH}" | dd of="${MATCHBOX_SYSTEM_DISK}" bs=4M conv=fsync status=progress
  sync

  partprobe "${MATCHBOX_SYSTEM_DISK}" || true
  lsblk -f "${MATCHBOX_SYSTEM_DISK}"

  mkdir -p "${SYS_BOOT_MP}"
  if mountpoint -q "${SYS_BOOT_MP}"; then
    umount "${SYS_BOOT_MP}" >/dev/null 2>&1 || true
  fi

  mount "$(matchbox_partition_path "${MATCHBOX_SYSTEM_DISK}" 1)" "${SYS_BOOT_MP}"
  printf '%s:%s\n' "${IDENTITY_USERNAME}" "${IDENTITY_PASSWORD_HASH}" > "${SYS_BOOT_MP}/userconf.txt"
  sync
  umount "${SYS_BOOT_MP}"
  log "userconf written"

  write_install_provenance "${MATCHBOX_SYSTEM_DISK}"

  teardown_installer_ssh

  echo
  show_completion_summary
  echo "Remove installer media"
  echo "Boot from NVMe"
}

main "$@"
